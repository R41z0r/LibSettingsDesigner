package-as: LibSettingsDesignerSample

enable-nolib-creation: no

ignore:
  - .github
  - docs
  - runtime
  - scripts
  - AGENTS.md
  - LibSettingsDesignerSample.toc
  - SKILL.md
  - README.md

manual-changelog:
  filename: CHANGELOG.md
  markup-type: markdown

move-folders:
  Samples/LibSettingsDesignerSample: LibSettingsDesignerSample
